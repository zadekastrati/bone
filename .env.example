APP_NAME="boné"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production: set APP_URL=https://your-domain.tld, APP_DEBUG=false, APP_FORCE_HTTPS=true
APP_FORCE_HTTPS=false

# Production deploy: PHP 8.2+, Composer 2.2+, Node 18+. Run scripts/deploy.sh or: composer install --no-dev && npm ci && npm run build && php artisan optimize && php artisan storage:link

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bone_app
DB_USERNAME=root
DB_PASSWORD=

# Railway: add the MySQL plugin and link it to this service. Laravel also reads MYSQLHOST, MYSQLPORT,
# MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD, MYSQL_URL if DB_* are unset (see config/database.php).
# Or set DATABASE_URL / MYSQL_URL to the connection string from the database service.

BROADCAST_DRIVER=log
CACHE_DRIVER=file
# Use "public" if you default to Storage::disk('public') without specifying disk; uploads use disk "public" in code.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
# Production: use database or redis + php artisan queue:work (order emails are queued when not sync)
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Production (HTTPS): SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=

# Behind nginx / Cloudflare / load balancer: TRUSTED_PROXIES=* (or comma-separated proxy IPs)
TRUSTED_PROXIES=

# Storefront (shipping rates are fixed per country in config/store.php: XK, AL, MK only)
STORE_CURRENCY=EUR
STORE_CURRENCY_SYMBOL=€
STORE_DEFAULT_COUNTRY=XK
STORE_BANK_ACCOUNT_NAME=
STORE_BANK_IBAN=
STORE_BANK_BIC=
STORE_BANK_REFERENCE_PREFIX=BONE
STORE_BANK_INSTRUCTIONS="Use your order number as the payment reference. Transfer may take 1–2 business days."

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — use smtp in production with your provider (Mailtrap, SendGrid, SES, etc.).
# Local dev: Mailpit (docker compose) on 127.0.0.1:1025, UI http://localhost:8025 — set MAIL_ENCRYPTION=null
# Production example (TLS): MAIL_PORT=587 MAIL_ENCRYPTION=tls
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Verify SMTP end-to-end: php artisan mail:test your@email.com
# Optional: php artisan mail:test your@email.com --order=1 (use a real order ID for the second email)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
